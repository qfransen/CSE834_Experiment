<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://sumo.dlr.de/xsd/routes_file.xsd">
    <vType id="basic_car" accel="0.8" decel="4.5" length="5" maxSpeed="20" guiShape="passenger"/>
    <vType id="cav_car" accel="0.8" decel="4.5" length="5" maxSpeed="20" guiShape="passenger" color="0,255,0">
        <param key="has.rerouting.device" value="true"/>
    </vType>
    <vType id="crash_car" accel="0.8" decel="4.5" length="5" maxSpeed="20" guiShape="passenger" color="255,0,0"/>

    <route id="route_main" edges="highway_start highway_middle highway_end"/>

    <vehicle id="target_car" type="crash_car" route="route_main" depart="0" departLane="1"/>

    <flow id="background_traffic" type="basic_car" route="route_main" begin="2" end="500" probability="0.95"/>
    <flow id="cav_traffic" type="cav_car" begin="2" end="500" probability="0.99" from="highway_start" to="highway_end"/>
</routes>